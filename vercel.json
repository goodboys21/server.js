{
  "version": 2,
  "name": "api-payment",
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    },
    { "src": "file/**/*.js", "use": "@vercel/node" }
  ],
  "routes": [
    {
      "src": "/image/(.*)",
      "dest": "/image/$1"
    },
    {
      "src": "/upload",
      "dest": "app.js"
    },
    { "src": "^/file/([^?]+)$", "dest": "/file/[data].js" },
    {
      "src": "/(.*)",
      "dest": "app.js"
    }
  ]
}
